<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.github.ydymovopenclawbot.stackworktree</id>
    <name>stack-worktree</name>
    <vendor>ydymovopenclaw-bot</vendor>

    <depends>com.intellij.modules.platform</depends>
    <depends>Git4Idea</depends>
    <depends>org.jetbrains.plugins.github</depends>
    <!--
      Terminal plugin: optional — the OpenInTerminalAction is loaded only when this
      plugin is present (registered in terminal-support.xml).  IDEA ships with the
      Terminal plugin bundled, so this is absent only in very stripped-down builds.
    -->
    <depends optional="true" config-file="terminal-support.xml">org.jetbrains.plugins.terminal</depends>

    <resource-bundle>messages.MyBundle</resource-bundle>

    <actions>
        <!--
          Context-menu action group shown when the user right-clicks a branch node
          in the Stacks graph panel.  The group itself is not shown as a top-level
          menu item; it is installed programmatically via PopupHandler in
          StacksTabFactory.
        -->
        <group id="StackWorktree.StackBranchPopup"
               text="Stack Branch Actions"
               popup="true">
            <action id="StackWorktree.InsertBranchAbove"
                    class="com.github.ydymovopenclawbot.stackworktree.actions.InsertBranchAboveAction"
                    text="Insert Branch Above"
                    description="Insert a new branch between this branch and its parent, then rebase this branch onto it"/>
            <action id="StackWorktree.InsertBranchBelow"
                    class="com.github.ydymovopenclawbot.stackworktree.actions.InsertBranchBelowAction"
                    text="Insert Branch Below"
                    description="Insert a new branch as a child of this branch and re-parent all existing children to it"/>
            <separator/>
            <action id="StackWorktree.RebaseOntoParent"
                    class="com.github.ydymovopenclawbot.stackworktree.actions.RebaseOntoParentAction"
                    text="Rebase onto Parent"
                    description="Rebase this branch onto its parent branch in the stack; opens IntelliJ's merge dialog on conflicts"/>
            <separator/>
            <action id="StackWorktree.CreateWorktree"
                    class="com.github.ydymovopenclawbot.stackworktree.actions.CreateWorktreeAction"
                    text="Create Worktree"
                    description="Create a linked git worktree for the selected branch"/>
            <action id="StackWorktree.RemoveWorktree"
                    class="com.github.ydymovopenclawbot.stackworktree.actions.RemoveWorktreeAction"
                    text="Remove Worktree"
                    description="Remove the linked git worktree bound to the selected branch"/>
        </group>
    </actions>

    <extensions defaultExtensionNs="com.intellij">
<postStartupActivity implementation="com.github.ydymovopenclawbot.stackworktree.startup.MyProjectActivity" />
        <changesViewContent
            id="Stacks"
            tabName="Stacks"
            className="com.github.ydymovopenclawbot.stackworktree.ui.StacksTabFactory"
            predicateClassName="com.github.ydymovopenclawbot.stackworktree.ui.StacksTabVisibilityPredicate"/>
        <changesViewContent
            id="Worktrees"
            tabName="Worktrees"
            className="com.github.ydymovopenclawbot.stackworktree.ui.WorktreesTabFactory"
            predicateClassName="com.github.ydymovopenclawbot.stackworktree.ui.StacksTabVisibilityPredicate"/>
        <statusBarWidgetFactory
            id="com.github.ydymovopenclawbot.stackworktree.StackStatusBarWidget"
            implementation="com.github.ydymovopenclawbot.stackworktree.ui.StackStatusBarWidgetFactory"
            order="after git"/>
        <projectService
            serviceImplementation="com.github.ydymovopenclawbot.stackworktree.state.StackStateService"/>

        <!-- Notification groups -->
        <notificationGroup id="StackTree" displayType="BALLOON" key="stacktree.notification.group"/>
        <notificationGroup id="StackWorktree" displayType="BALLOON"/>
        <notificationGroup id="Stack Worktree Notifications" displayType="BALLOON"/>

        <!-- PR layer services (S6.1 / S6.2) -->
        <!--
          AutodetectPrProvider inspects the project's git remotes at runtime and delegates
          to GitLabProvider (S6.2) or GitHubProvider (S6.1) as appropriate.
        -->
        <projectService
            serviceInterface="com.github.ydymovopenclawbot.stackworktree.pr.PrProvider"
            serviceImplementation="com.github.ydymovopenclawbot.stackworktree.pr.AutodetectPrProvider"/>
        <projectService
            serviceInterface="com.github.ydymovopenclawbot.stackworktree.pr.PrLayer"
            serviceImplementation="com.github.ydymovopenclawbot.stackworktree.pr.DefaultPrLayer"/>
        <applicationService
            serviceImplementation="com.github.ydymovopenclawbot.stackworktree.pr.gitlab.GitLabTokenStore"/>

        <!-- S7.1: Settings service + configurable -->
        <projectService
            serviceImplementation="com.github.ydymovopenclawbot.stackworktree.settings.StackTreeSettingsService"/>
        <projectConfigurable
            parentId="vcs"
            instance="com.github.ydymovopenclawbot.stackworktree.settings.StackTreeConfigurable"
            id="com.github.ydymovopenclawbot.stackworktree.settings.StackTreeConfigurable"
            displayName="StackTree"
            nonDefaultProject="true"/>

        <!-- State / Git / Ops / UI layer project services (S3.3) -->
        <projectService
            serviceInterface="com.github.ydymovopenclawbot.stackworktree.state.StateLayer"
            serviceImplementation="com.github.ydymovopenclawbot.stackworktree.state.StateLayerImpl"/>
        <projectService
            serviceInterface="com.github.ydymovopenclawbot.stackworktree.git.GitLayer"
            serviceImplementation="com.github.ydymovopenclawbot.stackworktree.git.GitLayerImpl"/>
        <projectService
            serviceInterface="com.github.ydymovopenclawbot.stackworktree.ops.OpsLayer"
            serviceImplementation="com.github.ydymovopenclawbot.stackworktree.ops.OpsLayerImpl"/>
        <projectService
            serviceInterface="com.github.ydymovopenclawbot.stackworktree.ui.UiLayer"
            serviceImplementation="com.github.ydymovopenclawbot.stackworktree.ui.UiLayerImpl"/>
    </extensions>

    <actions>
        <!-- S3.1: Create new stack -->
        <action id="StackTree.NewStack"
                class="com.github.ydymovopenclawbot.stackworktree.actions.NewStackAction"
                text="New Stack"
                description="Create a new branch stack"
                icon="AllIcons.General.Add"/>

        <!-- S4.3: Open worktree in new IDE window -->
        <action id="StackWorktree.OpenInNewWindow"
                class="com.github.ydymovopenclawbot.stackworktree.actions.OpenInNewWindowAction"
                text="Open in New Window"
                description="Open this worktree in a new IDE window (focuses existing window if already open)"/>

        <!-- S5.3: Sync with remote -->
        <action id="StackWorktree.Sync"
                class="com.github.ydymovopenclawbot.stackworktree.ui.actions.SyncAction"
                text="Sync"
                description="Fetch remote and sync stacks: detect merged branches, prune worktrees, and refresh ahead/behind counts"
                icon="AllIcons.Actions.Refresh">
            <add-to-group group-id="ChangesView.Toolbar" anchor="last"/>
            <!-- S7.2: Ctrl+Shift+Y — no conflict in default IntelliJ keymap -->
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl shift Y"/>
        </action>

        <!-- S6.3: Submit stack — push all branches and create/update PRs -->
        <action id="StackWorktree.SubmitStack"
                class="com.github.ydymovopenclawbot.stackworktree.ui.actions.SubmitAction"
                text="Submit Stack"
                description="Push all stack branches and create or update pull requests"
                icon="AllIcons.Actions.Upload">
            <add-to-group group-id="ChangesView.Toolbar" anchor="last"/>
            <!--
              S7.2: Ctrl+Alt+Shift+S avoids conflicts with:
                - Ctrl+Shift+S  = "Save All" (IdeaVim / File menu)
                - Ctrl+Alt+S    = Settings
            -->
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt shift S"/>
        </action>

        <action id="StackWorktree.RemoveStack"
                class="com.github.ydymovopenclawbot.stackworktree.actions.RemoveStackAction"
                text="Remove Stack"
                description="Remove all branches from the stack, optionally deleting git branches and worktrees"/>

        <action id="StackWorktree.CreateWorktreeFromBranch"
                class="com.github.ydymovopenclawbot.stackworktree.actions.CreateWorktreeFromBranchAction"
                text="Create Worktree"
                description="Create a git worktree for this branch"
                icon="AllIcons.Nodes.Folder">
            <add-to-group group-id="Git.Branches.List" anchor="last"/>
        </action>

        <!--
          Note: Track Branch and Untrack Branch are built programmatically inside
          StacksTabFactory's JPopupMenu and do not have standalone AnAction classes.
          Registration here for keyboard-shortcut / Find Action access is deferred
          to a future task.
        -->
        <!--
          Note: OpenInTerminalAction is registered in terminal-support.xml so it is
          loaded only when the Terminal plugin is present.
        -->
    </actions>

    <!--
        Note: AddBranchToStackAction is constructed programmatically by StacksTabFactory and
        is accessible only via the stack graph right-click context menu.  Registration in
        <actions> for keyboard-shortcut / Find Action access is deferred to a future task.
    -->

    <!--
      S7.2: StackTree Keymap group.

      All six StackTree toolbar actions appear here as a named group so they surface in
      Settings > Keymap > StackTree, allowing users to customise every shortcut.

      Layout:
        New Stack   — no default shortcut (user-assignable)
        Add Branch  — no default shortcut (user-assignable)
        Restack     — Ctrl+Alt+Shift+R  (avoids conflict with Ctrl+Shift+R = Replace in Path)
        Submit      — Ctrl+Alt+Shift+S  (registered on StackWorktree.SubmitStack above)
        Sync        — Ctrl+Shift+Y      (registered on StackWorktree.Sync above)
        Refresh     — F5

      The three actions with pre-existing IDs (StackTree.NewStack, StackWorktree.Sync,
      StackWorktree.SubmitStack) are included via <reference> so they appear in the Keymap
      group without being registered twice.  New actions (Restack, Refresh, AddBranch) are
      registered here for the first time.
    -->
    <actions>
        <group id="StackTree"
               text="StackTree"
               description="StackTree stacked-branch actions"
               popup="false">

            <!-- Already registered above; included here for Keymap grouping only. -->
            <reference ref="StackTree.NewStack"/>

            <!--
              Restack — Ctrl+Alt+Shift+R.
              Uses the same RestackAction class as the toolbar (instantiated fresh by the
              platform from the no-arg constructor, independent of the toolbar instance).
            -->
            <action id="StackWorktree.Restack"
                    class="com.github.ydymovopenclawbot.stackworktree.ui.actions.RestackAction"
                    text="Restack"
                    description="Rebase all stacks bottom-to-top onto their parents"
                    icon="AllIcons.General.Reset">
                <!--
                  Ctrl+Alt+Shift+R avoids conflict with:
                    - Ctrl+Shift+R = "Replace in Path" / "Run" (depending on keymap)
                -->
                <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt shift R"/>
            </action>

            <!--
              Add Branch — no default shortcut.
              Registered so the action is discoverable via Find Action and Keymap settings.
            -->
            <action id="StackWorktree.AddBranch"
                    class="com.github.ydymovopenclawbot.stackworktree.ui.actions.AddBranchAction"
                    text="Add Branch"
                    description="Add a branch to the current stack"
                    icon="AllIcons.Vcs.Branch"/>

            <!-- Submit and Sync — keyboard shortcuts added directly to their <action> elements above. -->
            <reference ref="StackWorktree.SubmitStack"/>
            <reference ref="StackWorktree.Sync"/>

            <!--
              Refresh — F5.
              Uses the no-arg constructor of RefreshStacksAction, which falls back to
              UiLayer.refresh() (publishes STACK_STATE_TOPIC → StacksTabFactory.performRefresh).
            -->
            <action id="StackWorktree.Refresh"
                    class="com.github.ydymovopenclawbot.stackworktree.ui.actions.RefreshStacksAction"
                    text="Refresh"
                    description="Reload stack state and recalculate ahead/behind counts"
                    icon="AllIcons.Actions.Refresh">
                <keyboard-shortcut keymap="$default" first-keystroke="F5"/>
            </action>
        </group>
    </actions>
</idea-plugin>

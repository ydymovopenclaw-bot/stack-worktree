# EditorConfig helps maintain consistent coding styles across editors and IDEs.
# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

[*.{yml,yaml}]
indent_size = 2

[*.{json,toml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.{kt,kts}]
indent_size = 4

[*.xml]
indent_size = 4

[Makefile]
indent_style = tab
